# =============================================================================
# Backend (API) — copie as linhas VAR=valor para Easypanel > App da API > Ambiente
# Substitua os placeholders; não commite este ficheiro preenchido com segredos.
# =============================================================================

NODE_ENV=production
PORT=3005

# Connection string do PostgreSQL (Easypanel Postgres ou externo)
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO

JWT_SECRET=COLOQUE_UMA_CHAVE_LONGA_E_ALEATORIA
JWT_EXPIRES_IN=7d

# URL pública do site (sem barra no fim) — deve ser o mesmo domínio do serviço Web
FRONTEND_ORIGIN=https://seudominio.com

# Diretório de uploads dentro do container — monte volume SÓ em /app/uploads (não em /app inteiro)
UPLOAD_DIR=/app/uploads

# Mesmo domínio público (para links /uploads/... no HTML e JSON)
UPLOAD_PUBLIC_BASE_URL=https://seudominio.com

# --- Opcional: só para scripts manuais no container (migrate já usa DATABASE_URL) ---
# MIGRATIONS_DIR=postgres/migrations

# --- Só ao correr seed-admin uma vez (console / one-shot) ---
# ADMIN_EMAIL=admin@seudominio.com
# ADMIN_PASSWORD=SuaSenhaForte
# BCRYPT_ROUNDS=12
